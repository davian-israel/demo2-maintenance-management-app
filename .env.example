# SQLite connection string for Prisma
DATABASE_URL="file:./dev.db"

# Production template (set this in .env.production.local and Vercel):
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require&channel_binding=require"

# Source workbook used by one-time import command
SABBATH_WORKBOOK_PATH="/Users/davian/Desktop/projects/maintenance-israel/WIP - Maintenance Sabbath Check.xlsx"

# Set true to fail import when warnings are produced
IMPORT_STRICT="false"

# Set true in local/test if you want to run with in-memory repositories
USE_IN_MEMORY_REPO="false"

# Checklist domain rollout flag (set false to disable checklist APIs/UI workflow)
FEATURE_CHECKLIST_ENABLED="true"
